generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  apiToken     String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions Transaction[]
  incomeEvents IncomeEvent[]
  categories   Category[]
  settings     Settings?
}

model Transaction {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount     Int
  currency   String   @default("EUR")
  merchant   String
  category   String?
  note       String?
  source     String   @default("manual")
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, occurredAt])
  @@index([userId, category])
}

model IncomeEvent {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount     Int       // cents
  currency   String   @default("EUR")
  note       String?   // e.g. "Q1 bonus", "side project"
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, occurredAt])
}

model Settings {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period           String   @default("month") // week | month | year
  monthlyResetDay  Int      @default(1)        // 1-31 (clamped to last day of month)
  weeklyResetDay   Int      @default(1)        // 0=Sun ... 6=Sat
  yearlyResetMonth Int      @default(1)        // 1-12
  yearlyResetDay   Int      @default(1)        // 1-31
  incomeAmount     Int      @default(0)        // cents, per period
  locale           String   @default("en")     // en | bg
  currency         String   @default("EUR")    // EUR | USD | GBP
  updatedAt        DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  emoji     String
  position  Int      @default(0)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, archived, position])
}
